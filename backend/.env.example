PORT=8000
MONGODB_URI=mongodb://localhost:27017/projectcamp
CLIENT_URL=http://localhost:5173

# Clerk (publishable key = same as frontend; secret = from dashboard.clerk.com)
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret

# Mailer – Gmail (use App Password, not your normal password)
# 1. Google Account → Security → 2-Step Verification ON
# 2. Security → App passwords → generate one for "Mail"
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your.email@gmail.com
MAIL_PASS=your-16-char-app-password
MAIL_FROM=ProjectCamp <your.email@gmail.com>
